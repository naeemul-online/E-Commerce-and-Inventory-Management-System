model ChatSession {
  id        String        @id @default(cuid())
  userId    String?
  fullName  String
  phone     String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
  user      User?         @relation(fields: [userId], references: [id])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  sender    String
  message   String
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id])
}

model Coupon {
  id          String    @id @default(cuid())
  code        String    @unique
  description String?
  discount    Float
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  content   String
  rating    Int      @db.SmallInt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
